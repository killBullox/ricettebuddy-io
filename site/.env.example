# Credenziali FTP hosting Aruba — copia questo file in ".env" e compila.
# NON committare .env (è gitignorato).

# Host FTP Aruba (di solito il tuo dominio o ftp.<dominio>, oppure l'host indicato
# nel pannello Aruba alla voce "Account FTP").
FTP_HOST=ftp.iltuodominio.it

# Utente e password FTP (dal pannello Aruba > Gestione Hosting > Account FTP).
FTP_USER=
FTP_PASS=

# Cartella pubblica dove Aruba serve il sito. Su Aruba Linux è spesso "/" (root
# dell'account FTP) oppure "/htdocs" o "/www". Verifica nel pannello.
FTP_DIR=/

# Porta FTP (21 standard). Se Aruba richiede FTPS esplicito, dillo e adatto lo script.
FTP_PORT=21
